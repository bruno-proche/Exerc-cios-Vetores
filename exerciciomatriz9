/******************************************************************************

Faça um algoritmo que leia duas matrizes X e Y, quadradas com ordem 5, e faça as 
seguintes manipulações: 
• Gere uma matriz W com os menores elementos entre as matrizes X e Y, ou seja, um 
elemento Wij possui o menor valor entre os elementos Xij e Yij. Se os elementos forem 
iguais ambos são o menor valor. check
• Gere um vetor com os elementos da diagonal principal da matriz X; check
• Encontre a coluna da matriz Y que possui a menor soma do valor de seus elementos 
dentre todas as colunas da matriz, e mostre qual é a posição dessa coluna. Caso 
existam somas de colunas iguais considerar a primeira coluna com a ocorrência do 
valor.

*******************************************************************************/
#include <iostream>
using namespace std;
#define max 5
#include <time.h>

int main()
{
    int matriz_x[max][max], matriz_y[max][max], matriz_w[max][max], vetor[max], soma = 0, menorsoma, posicao;
    srand(time(NULL));
    
    cout<<"Matriz X: "<<endl;
    for (int i = 0; i < max; i++){
        for (int j = 0; j < max; j++){
            matriz_x[i][j] = rand() % 20;
            cout<<matriz_x[i][j]<<"  ";
            if (i == j){
                vetor[i] = matriz_x[i][j];
            }
        }
        cout<<endl;
    }
    cout<<"\nMatriz Y: "<<endl;
    for (int i = 0; i < max; i++){
        for (int j = 0; j < max; j++){
            matriz_y[i][j] = rand() % 20;
            cout<<matriz_y[i][j]<<"  ";
        }
        cout<<endl;
    }
    cout<<"\nMatriz W: "<<endl;
    for (int i = 0; i < max; i++){
        for (int j = 0; j < max; j++){
            if (matriz_y[i][j] < matriz_x[i][j]){
                matriz_w [i][j] = matriz_y[i][j];
            }
            else if (matriz_x[i][j] < matriz_y[i][j]){
                matriz_w[i][j] = matriz_x[i][j]; 
            }
            else{
                matriz_w[i][j] = matriz_x[i][j];
            }
            cout<<matriz_w[i][j]<<"  ";
        }
        cout<<endl;
    }
    for (int j = 0; j < max; j++){
        soma = 0;
        for (int i = 0; i < max; i++){
            soma+= matriz_y[i][j];
        }
        if (j == 0){
                menorsoma = soma;
                posicao = j;
            }
            else if (soma < menorsoma ){
                menorsoma = soma;
                posicao = j;
            }
    }
    
    cout<<"\nMenor soma das colunas da matriz Y: "<<menorsoma<<endl;
    cout<<"Posição [ "<<posicao<<" ]";
    return 0;
}
