        }
        cout<< endl;
    }
    for(int linha = 0; linha < 5 ; linha++){
        for(int coluna = 0; coluna < 5; coluna++){
            if (linha == 0  && coluna < 5) {
                soma+= matriz[linha][coluna];
            } else if (linha == 1 && coluna >= 1 && coluna < 4) {
                soma+= matriz[linha][coluna];
            } else if (linha == 2 && coluna == 2) {
                soma+= matriz[linha][coluna];
            } else if (linha == 3 && coluna >= 1 && coluna < 4) {
                soma += matriz[linha][coluna];
            } else if (linha == 4 && coluna < 5){
                soma += matriz[linha][coluna];
            }
    }
    cout << endl;
}
    cout << "Soma dos elementos da area azul: " << soma << endl;
    

   
    return 0;
