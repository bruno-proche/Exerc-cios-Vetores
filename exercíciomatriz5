#include <iostream>
#include <locale.h>
using namespace std;
#include <time.h>
#define MAX 4

/**Faça um programa que leia uma matriz 4 x 4 e que logo em seguida realize o somatório de 
todos elementos contidos na diagonal secundária. Exiba o resultado. */

int main() {

    int matriz[MAX][MAX];
    int soma = 0;
    setlocale(LC_ALL, "Portuguese");
    
    for (int i = 0; i < MAX; i++){
        for (int j = 0; j < MAX; j++){
            cout<<"Digite o valor da posição ["<<i<<"]["<<j<<"]: ";
            cin>>matriz[i][j];
        }
    }
    for (int i = 0; i < MAX; i++){
        for (int j = 0; j < MAX; j++){
            cout<<matriz[i][j]<<" ";
        }
        cout<<endl;
    }
    for (int i = 0; i < MAX; i++){
        for (int j = 0; j < MAX; j++){
            if (i + j == MAX - 1){
                soma += matriz[i][j];
            }
            
        }
    }
    cout<<"Soma dos elementos da diagonal secundária: "<<soma<<endl;

    return 0;
}
