#include <iostream>
using namespace std;
#define MAX 5

int main() {

    int matriz[MAX][MAX], resultado = 0;
    for (int i = 0; i < MAX; i++){
        for (int j = 0; j < MAX; j++){
            matriz[i][j] = i + j;
        }
    }
    for (int i = 0; i < MAX; i++){
        for (int j = 0; j < MAX; j++){
            resultado += matriz[i][j];   
        }
        cout << endl;
    }
    cout << resultado << " ";   
    return 0;
}
