#include <iostream>
using namespace std;
#include <cstdlib>
#include <ctime>



int main(){
    int matriz [5][5];

    for (int i = 0; i < 5; i++){
        for (int j = 0; j < 5; j++){
            if (i == j){
                matriz[i][j] = 0;
            } else if (i - j == 1 || j - i == 1){
                matriz[i][j] = 1;
            } else if (i - j == 2 || j - i == 2){
                matriz[i][j] = 0;
            } else if (i - j == 3 || j - i == 3){
                matriz[i][j] = 1;
            } else if (i - j == 4 || j - i == 4){
                matriz[i][j] = 0;
            }
            cout << matriz[i][j] << " ";
        }
        cout<<endl;
    }
    return 0;
}
