    }
    cout << "Somas das linhas: ";
    for (int i = 0; i < MAX; i++){
        cout << vetor_linhas[i] << " ";
    }
    cout << endl;
    cout << "Somas das colunas: ";
    for (int i = 0; i < MAX; i++){
        cout << vetor_colunas[i] << " ";
    }
    cout << endl;

    return 0;
}
