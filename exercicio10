/******************************************************************************

. Escreva um algoritmo que solicite ao usuário a entrada de 5 números, e que exiba o 
somatório desses números na tela. Após exibir a soma, o programa deve mostrar também os 
números que o usuário digitou, um por linha.

*******************************************************************************/
#include <iostream>
using namespace std;
#define TAM 5
int main()
{
    int vet[TAM], resultado = 0;
    
    for (int i = 0; i < TAM; i++){
        cout<<"Digite cinco valores: ";
        cin>>vet[i];
    }
    for (int i = 0; i < TAM; i++){
        resultado += vet[i];
    }
    
    cout<<"Resultado da soma dos cinco números: "<<resultado<<endl<<endl;
    
    for (int i = 0; i < TAM; i++){
      cout<<"Posição: "<<i<<" número: "<<vet[i]<<endl;
    }
    
    return 0;
}
