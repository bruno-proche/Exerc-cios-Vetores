/******************************************************************************

 Leia um vetor de 40 posições e atribua valor 0 para todos os elementos que possuírem 
valores negativos

*******************************************************************************/
#include <iostream>
using namespace std;
#define TAM 40
int main()
{
    int vet[TAM];
    
    for (int i = 0; i < TAM; i++){
        cout<<"Digite 40 valores para o vetor: ";
        cin>>vet[i];
        
    }
    for (int i = 0; i < TAM; i++){
        if (vet[i] < 0){
            vet [i] = 0;
        }
    }
    for (int i = 0; i < TAM; i++){
        cout<<vet[i]<<endl;
    }
    return 0;
}
